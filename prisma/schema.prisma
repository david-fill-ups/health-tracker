generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth (NextAuth / Auth.js Prisma Adapter) ─────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  profiles         Profile[]
  profileAccess    ProfileAccess[]
  sentInvitations  ProfileInvitation[] @relation("SentInvitations")
  auditLogs        AuditLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Profiles ─────────────────────────────────────────────────────────────────

enum Sex {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum FamilySide {
  MATERNAL
  PATERNAL
}

enum FamilyRelationship {
  // Legacy (kept for existing records)
  PARENT
  SIBLING
  // Current — gendered
  FATHER
  MOTHER
  BROTHER
  SISTER
  HALF_BROTHER
  HALF_SISTER
  GRANDFATHER
  GRANDMOTHER
  AUNT
  UNCLE
  SON
  DAUGHTER
}

enum ProfileRelationshipType {
  // Kept for backward compatibility with any existing records
  PARENT
  CHILD
  SIBLING
  HALF_SIBLING
  GRANDPARENT
  GRANDCHILD
  AUNT_UNCLE
  NIECE_NEPHEW
  STEP_PARENT
  STEP_CHILD
  IN_LAW

  SPOUSE

  // Parents
  MOTHER
  FATHER

  // Children
  DAUGHTER
  SON

  // Siblings
  SISTER
  BROTHER
  HALF_SISTER
  HALF_BROTHER

  // Grandparents
  MATERNAL_GRANDMOTHER
  MATERNAL_GRANDFATHER
  PATERNAL_GRANDMOTHER
  PATERNAL_GRANDFATHER

  // Grandchildren
  GRANDDAUGHTER
  GRANDSON

  // Aunts & Uncles
  MATERNAL_AUNT
  MATERNAL_UNCLE
  PATERNAL_AUNT
  PATERNAL_UNCLE

  // Nieces & Nephews
  NIECE
  NEPHEW

  COUSIN

  // Step family
  STEP_MOTHER
  STEP_FATHER
  STEP_DAUGHTER
  STEP_SON
  STEP_SISTER
  STEP_BROTHER

  // In-laws
  MOTHER_IN_LAW
  FATHER_IN_LAW
  DAUGHTER_IN_LAW
  SON_IN_LAW
  SISTER_IN_LAW
  BROTHER_IN_LAW

  OTHER
}

enum ProfilePermission {
  OWNER
  WRITE
  READ_ONLY
}

model Profile {
  id             String   @id @default(cuid())
  userId         String
  isOwnerProfile Boolean  @default(false)
  name           String
  birthDate      DateTime
  sex            Sex
  state          String?
  notes          String?
  calendarToken  String   @unique @default(cuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  owner         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  access        ProfileAccess[]
  invitations   ProfileInvitation[]
  visits        Visit[]
  conditions    Condition[]
  vaccinations  Vaccination[]
  medications   Medication[]
  facilities    Facility[]
  doctors       Doctor[]
  allergies              Allergy[]
  portals                Portal[]
  healthMetrics          HealthMetric[]
  familyMembers          FamilyMember[]
  outgoingRelationships  ProfileRelationship[] @relation("RelationshipsFrom")
  incomingRelationships  ProfileRelationship[] @relation("RelationshipsTo")
}

model ProfileAccess {
  id         String            @id @default(cuid())
  profileId  String
  userId     String
  permission ProfilePermission @default(OWNER)
  createdAt  DateTime          @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([profileId, userId])
}

model ProfileInvitation {
  id         String            @id @default(cuid())
  profileId  String
  email      String
  permission ProfilePermission @default(READ_ONLY)
  invitedBy  String
  createdAt  DateTime          @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  inviter User    @relation("SentInvitations", fields: [invitedBy], references: [id], onDelete: Cascade)

  @@unique([profileId, email])
  @@index([email])
}

// ─── Healthcare Team ──────────────────────────────────────────────────────────

model Facility {
  id         String   @id @default(cuid())
  profileId  String
  name       String
  type       String   @default("Clinic")
  rating     Float?
  websiteUrl String?
  portalUrl  String?
  phone      String?
  notes      String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  profile      Profile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  locations    Location[]
  doctors      Doctor[]
  visits       Visit[]
  vaccinations Vaccination[]
  portals      Portal[]

  @@index([profileId])
}

model Location {
  id         String   @id @default(cuid())
  facilityId String
  name       String
  address1   String?
  address2   String?
  city       String?
  state      String?
  zip        String?
  phone      String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  visits   Visit[]

  @@index([facilityId])
}

model Doctor {
  id         String   @id @default(cuid())
  profileId  String
  name       String
  specialty  String?
  facilityId String?
  rating     Float?
  websiteUrl String?
  portalUrl  String?
  phone      String?
  notes      String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  profile     Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  facility    Facility?    @relation(fields: [facilityId], references: [id])
  visits      Visit[]
  medications Medication[]

  @@index([profileId])
  @@index([facilityId])
}

// ─── Visits / Appointments ────────────────────────────────────────────────────

enum VisitType {
  ROUTINE
  LAB
  SPECIALIST
  URGENT
  TELEHEALTH
  PROCEDURE
  OTHER
}

enum VisitStatus {
  PENDING
  SCHEDULED
  COMPLETED
  CANCELLED
}

model Visit {
  id         String      @id @default(cuid())
  profileId  String
  doctorId   String?
  facilityId String?
  locationId String?
  date        DateTime?
  dueMonth    String?
  type        VisitType   @default(ROUTINE)
  reason      String?
  specialty   String?
  notes       String?
  documentUrl String?
  status      VisitStatus @default(PENDING)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  profile  Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  doctor   Doctor?   @relation(fields: [doctorId], references: [id])
  facility Facility? @relation(fields: [facilityId], references: [id])
  location Location? @relation(fields: [locationId], references: [id])

  @@index([profileId])
  @@index([doctorId])
  @@index([facilityId])
  @@index([locationId])
}

// ─── Medications ──────────────────────────────────────────────────────────────

model Medication {
  id                  String    @id @default(cuid())
  profileId           String
  name                String
  dosage              String?
  frequency           String?
  prescribingDoctorId String?
  startDate           DateTime?
  endDate             DateTime?
  instructions        String?
  active              Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  profile           Profile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  prescribingDoctor Doctor?         @relation(fields: [prescribingDoctorId], references: [id])
  logs              MedicationLog[]

  @@index([profileId])
  @@index([prescribingDoctorId])
}

model MedicationLog {
  id            String   @id @default(cuid())
  medicationId  String
  date          DateTime
  dosage        Float?
  unit          String?
  injectionSite String?
  weight        Float?
  notes         String?
  createdAt     DateTime @default(now())

  medication Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)

  @@index([medicationId])
}

// ─── Conditions ───────────────────────────────────────────────────────────────

enum ConditionStatus {
  ACTIVE
  RESOLVED
  MONITORING
  BENIGN
}

model Condition {
  id            String          @id @default(cuid())
  profileId     String
  name          String
  diagnosisDate DateTime?
  status        ConditionStatus @default(ACTIVE)
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

// ─── Vaccinations ─────────────────────────────────────────────────────────────

enum VaccinationSource {
  ADMINISTERED
  NATURAL
  DECLINED
}

model Vaccination {
  id         String            @id @default(cuid())
  profileId  String
  name       String
  date       DateTime
  source     VaccinationSource @default(ADMINISTERED)
  facilityId String?
  lotNumber  String?
  notes      String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  profile  Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  facility Facility? @relation(fields: [facilityId], references: [id])

  @@index([profileId])
  @@index([facilityId])
}

// ─── CDC Schedule ─────────────────────────────────────────────────────────────

model CdcScheduleVersion {
  id          String   @id @default(cuid())
  version     String
  lastUpdated DateTime
  data        Json
  createdAt   DateTime @default(now())

  @@index([lastUpdated])
}

// ─── Allergies ────────────────────────────────────────────────────────────────

model Allergy {
  id            String    @id @default(cuid())
  profileId     String
  allergen      String
  category      String?
  diagnosisDate DateTime?
  whealSize     Float?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

// ─── Portals ──────────────────────────────────────────────────────────────────

model Portal {
  id           String   @id @default(cuid())
  profileId    String
  name         String
  organization String?
  url          String
  facilityId   String?
  notes        String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile  Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  facility Facility? @relation(fields: [facilityId], references: [id])

  @@index([profileId])
  @@index([facilityId])
}

// ─── Health Metrics ───────────────────────────────────────────────────────────

model HealthMetric {
  id         String   @id @default(cuid())
  profileId  String
  metricType String
  value      Float
  unit       String
  measuredAt DateTime
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([profileId, metricType])
  @@index([profileId, measuredAt])
}

// ─── Family Medical History ───────────────────────────────────────────────────

model FamilyMember {
  id           String             @id @default(cuid())
  profileId    String
  name         String
  relationship FamilyRelationship
  side         FamilySide?
  notes        String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  profile    Profile             @relation(fields: [profileId], references: [id], onDelete: Cascade)
  conditions FamilyCondition[]

  @@index([profileId])
}

model FamilyCondition {
  id             String   @id @default(cuid())
  familyMemberId String
  name           String
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  familyMember FamilyMember @relation(fields: [familyMemberId], references: [id], onDelete: Cascade)

  @@index([familyMemberId])
}

model ProfileRelationship {
  id            String                  @id @default(cuid())
  fromProfileId String
  toProfileId   String
  relationship  ProfileRelationshipType
  biological    Boolean                 @default(true)
  createdAt     DateTime                @default(now())

  fromProfile Profile @relation("RelationshipsFrom", fields: [fromProfileId], references: [id], onDelete: Cascade)
  toProfile   Profile @relation("RelationshipsTo",   fields: [toProfileId],   references: [id], onDelete: Cascade)

  @@unique([fromProfileId, toProfileId])
  @@index([fromProfileId])
}

// ─── Audit Log ────────────────────────────────────────────────────────────────
// Immutable record of all create / update / delete operations on health data.
// Provides accountability for who changed what and when.

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  profileId  String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([profileId, createdAt])
}
